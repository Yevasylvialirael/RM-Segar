rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "a80517426@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Validation Blueprints ---

    function isValidCartItem(item) {
      return item.id is string && item.id.size() <= 100 &&
             item.name is string && item.name.size() <= 200 &&
             item.price is number && item.price >= 0 &&
             item.quantity is number && item.quantity > 0 &&
             (!('option' in item) || (item.option in ['Es', 'Panas'])) &&
             (!('sweetness' in item) || (item.sweetness in ['Manis', 'Tawar', 'Sedikit Gula'])) &&
             (!('note' in item) || (item.note is string && item.note.size() <= 500));
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'phone']) &&
             data.userId == request.auth.uid &&
             data.phone is string && data.phone.size() <= 20 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'userId', 'items', 'totalItems', 'orderType', 'paymentMethod', 'createdAt']) &&
             data.id is string && data.id.size() <= 64 &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() <= 50 &&
             data.totalItems is number && data.totalItems >= 0 &&
             data.orderType in ['Makan di Tempat', 'Bungkus', 'Jadwalkan'] &&
             data.paymentMethod in ['Tunai', 'Transfer'] &&
             data.createdAt == request.time &&
             (!('note' in data) || (data.note is string && data.note.size() <= 1000)) &&
             (!('status' in data) || (data.status in ['Pending', 'Processing', 'Selesai', 'Batal']));
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['id', 'userId', 'date', 'time', 'attendees', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 64 &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.size() <= 20 &&
             data.time is string && data.time.size() <= 10 &&
             data.attendees is number && data.attendees > 0 &&
             data.status in ['Akan Datang', 'Selesai', 'Dibatalkan'] &&
             data.createdAt == request.time &&
             (!('note' in data) || (data.note is string && data.note.size() <= 1000));
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['phone', 'displayName', 'photoURL', 'updatedAt']);
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(existing().userId) && 
         existing().status in ['Pending', 'Processing'] && 
         incoming().userId == existing().userId &&
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['note', 'status']))
      );
      allow delete: if isAdmin();
    }

    match /reservations/{resId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidReservation(incoming()) && isValidId(resId);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(existing().userId) && 
         existing().status == 'Akan Datang' && 
         incoming().userId == existing().userId &&
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'attendees', 'note', 'status']))
      );
      allow delete: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or Admin SDK
    }
  }
}
